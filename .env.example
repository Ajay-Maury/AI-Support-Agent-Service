# ── Environment Variables for RAG Support System ─────────────────────────────
NODE_ENV=development
PORT=3000

# ── MongoDB Atlas ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=rag_support_agent

# ── AI Service API ──────────────────────────────────────────────────
FASTAPI_URL=http://ai-service:8000

# ── Groq API ──────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-8b-instant  #fastest, recommended

# ── Chunking (optional — defaults shown) ──────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval (optional — defaults shown) ─────────────────────
TOP_K=3
MIN_SCORE=0.70
NUM_CANDIDATES=100
